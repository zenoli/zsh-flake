{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#F1FA8C",
          "options": {
            "style": "full",
            "mapped_locations": {
              "~/nix-config/": "󱄅 nix-config"
            }
          },
          "template": "<#42E66C>\ueaf7 </><b>{{ .Path }}</b>",
          "type": "path"
        },
        {
          "foreground": "#43CCEA",
          "options": {
            "branch_icon": ""
          },
          "template": "<#ffffff> \u26A1 </><b>{{ .HEAD }}</b>",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "nix-shell",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#ffffff",
          "background": "blue",
          "template": "{{ if or (eq .Type \"pure\") (eq .Type \"impure\") }}󱄅 ({{ .Type }}){{ end }}"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#FFFFFF",
          "style": "plain",
          "template": "󰘧 " ,
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
